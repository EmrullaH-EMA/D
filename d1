// Types
interface BotStatus {
  isRunning: boolean;
  mode: 'paper' | 'live';
  equity: number;
  openPositions: Position[];
  todayPnl: number;
  winRate: number;
  totalTrades: number;
  currentRegime: string;
  aiConfidence: number;
}

interface Position {
  id: string;
  symbol: string;
  side: 'long' | 'short';
  size: number;
  entryPrice: number;
  currentPrice: number;
  pnl: number;
  duration: number;
}

interface Trade {
  id: string;
  side: string;
  entry: number;
  exit: number;
  pnl: number;
  duration: number;
  regime: string;
}

// Mock data generators
const generateEquityData = () => {
  const data = [];
  let equity = 10000;
  for (let i = 0; i < 100; i++) {
    equity *= (1 + (Math.random() - 0.4) * 0.02);
    data.push({
      time: `T-${100-i}`,
      equity: equity,
      benchmark: 10000 * (1 + i * 0.001)
    });
  }
  return data;
};

const generateTradeHistory = (): Trade[] => {
  return Array.from({ length: 20 }, (_, i) => ({
    id: `TRADE_${i}`,
    side: Math.random() > 0.4 ? 'long' : 'short',
    entry: 50000 + Math.random() * 5000,
    exit: 50000 + Math.random() * 5000,
    pnl: (Math.random() - 0.3) * 4,
    duration: 15 + Math.random() * 30,
    regime: ['bull_trend', 'bear_range', 'high_vol'][Math.floor(Math.random() * 3)]
  }));
};

export default function Dashboard() {
  const [activeTab, setActiveTab] = useState<'overview' | 'backtest' | 'trades' | 'settings'>('overview');
