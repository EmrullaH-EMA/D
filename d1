// Component Definitions
function StatCard({ title, value, change, subtext, icon: Icon, color }: any) {
  const colors = {
    emerald: 'from-emerald-500 to-emerald-600',
    blue: 'from-blue-500 to-blue-600',
    purple: 'from-purple-500 to-purple-600',
    orange: 'from-orange-500 to-orange-600',
  };

  return (
    <div className="bg-slate-900/50 border border-slate-800 rounded-2xl p-6 hover:border-slate-700 transition-all">
      <div className="flex items-start justify-between">
        <div>
          <p className="text-slate-400 text-sm mb-1">{title}</p>
          <h3 className="text-2xl font-bold text-white">{value}</h3>
          {change !== undefined && (
            <p className={`text-sm mt-1 ${change >= 0 ? 'text-emerald-400' : 'text-red-400'}`}>
              {change >= 0 ? '↑' : '↓'} {Math.abs(change).toFixed(2)}%
            </p>
          )}
          {subtext && <p className="text-xs text-slate-500 mt-1">{subtext}</p>}
        </div>
        <div className={`p-3 rounded-xl bg-gradient-to-br ${colors[color as keyof typeof colors]} bg-opacity-20`}>
          <Icon className="w-6 h-6 text-white" />
        </div>
      </div>
    </div>
  );
}

function MetricRow({ label, value, negative = false }: { label: string, value: string, negative?: boolean }) {
  return (
    <div className="flex items-center justify-between py-2 border-b border-slate-800/50 last:border-0">
      <span className="text-slate-400 text-sm">{label}</span>
      <span className={`font-mono font-medium ${negative ? 'text-red-400' : 'text-emerald-400'}`}>
        {value}
      </span>
    </div>
  );
}

function EvolutionItem({ generation, change, impact, status }: { generation: number, change: string, impact: string, status: 'success' | 'pending' | 'failed' }) {
  const statusColors = {
    success: 'bg-emerald-500',
    pending: 'bg-amber-500',
    failed: 'bg-red-500'
  };

  return (
    <div className="flex items-center gap-3 p-3 bg-slate-800/50 rounded-lg">
      <div className={`w-2 h-2 rounded-full ${statusColors[status]} ${status === 'pending' ? 'animate-pulse' : ''}`} />
      <div className="flex-1">
        <div className="flex items-center justify-between">
          <span className="text-sm font-medium">Gen {generation}</span>
          <span className={`text-xs ${status === 'success' ? 'text-emerald-400' : 'text-amber-400'}`}>
            {impact}
          </span>
        </div>
        <p className="text-xs text-slate-400">{change}</p>
      </div>
    </div>
  );
}
